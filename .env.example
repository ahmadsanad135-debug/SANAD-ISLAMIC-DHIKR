# Firebase Environment Variables - يجب نسخ هذا الملف إلى .env وملء القيم
# IMPORTANT: لا تشارك هذا الملف أو .env في أي مكان عام

# Firebase API Key - احصل عليه من Firebase Console
VITE_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=islamic-dhikr.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=islamic-dhikr

# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=islamic-dhikr.firebasestorage.app

# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=335914729881

# Firebase App ID
VITE_FIREBASE_APP_ID=1:335914729881:web:ab4f5e4c8added6fc65308

# Firebase Measurement ID (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=G-M3GKFFF5YR

# Firebase VAPID Key - للإشعارات
VITE_FIREBASE_VAPID_KEY=BGVg3N1OvvzczIpOj4NuyGPtCqm-gVdNYd1U-ZIM1-DNmu6BWYHcXulbwsxQyq7kB6rVJaPbKxCSRLq1n8RUaS0

# ملاحظات مهمة:
# 1. هذا الملف يجب أن يكون .env.example (بدون القيم الحقيقية)
# 2. الملف الفعلي .env يجب أن يكون في .gitignore
# 3. لا تضع مفاتيح حقيقية هنا، فقط في ملف .env المحلي
